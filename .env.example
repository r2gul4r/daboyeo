# daboyeo portfolio environment example
# Copy values into `.env` for local work.
# Keep real credentials out of git.

# -----------------------------------------------------------------------------
# minimal backend demo
# -----------------------------------------------------------------------------
# `/api/health` can run with defaults only.
# Set this only when you want a custom port.
DABOYEO_BACKEND_PORT=8080

# -----------------------------------------------------------------------------
# backend with database-backed APIs
# -----------------------------------------------------------------------------
# Collector verification scripts can reuse these same DB settings.
DABOYEO_DB_URL=jdbc:mysql://localhost:4000/daboyeo?serverTimezone=Asia/Seoul&characterEncoding=utf8&useSSL=false
DABOYEO_DB_USERNAME=root
DABOYEO_DB_PASSWORD=
DABOYEO_FLYWAY_ENABLED=false
DABOYEO_FRONTEND_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://*:4173,http://localhost:5173,http://127.0.0.1:5173,http://*:5173
DABOYEO_DEMO_LIVE_FALLBACK_ENABLED=true

# -----------------------------------------------------------------------------
# optional scheduled sync
# -----------------------------------------------------------------------------
DABOYEO_SYNC_ENABLED=false
DABOYEO_SYNC_TIMEZONE=Asia/Seoul
DABOYEO_SYNC_PYTHON=python
DABOYEO_SYNC_TIMEOUT_SECONDS=180
DABOYEO_SHOWTIME_SYNC_ENABLED=false
DABOYEO_SHOWTIME_SYNC_CRON=0 0 3 * * *
DABOYEO_SHOWTIME_DATE_OFFSETS=0,1
DABOYEO_SEAT_SYNC_ENABLED=false
DABOYEO_SEAT_SYNC_CRON=0 0/30 * * * *
DABOYEO_SEAT_SYNC_LOOKAHEAD_HOURS=6
DABOYEO_SEAT_SYNC_LIMIT=100

# -----------------------------------------------------------------------------
# optional local LM Studio recommendation setup
# -----------------------------------------------------------------------------
DABOYEO_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
DABOYEO_RECOMMEND_FAST_MODEL=gemma-4-e2b-it
DABOYEO_RECOMMEND_PRECISE_MODEL=gemma-4-e4b-it
DABOYEO_RECOMMEND_MIN_START_BUFFER_MINUTES=20
DABOYEO_RECOMMEND_FAST_AI_CANDIDATE_LIMIT=5
DABOYEO_RECOMMEND_PRECISE_AI_CANDIDATE_LIMIT=5
DABOYEO_RECOMMEND_FAST_MAX_TOKENS=280
DABOYEO_RECOMMEND_PRECISE_MAX_TOKENS=160
DABOYEO_RECOMMEND_RESPONSE_TEXT_MAX_LENGTH=56

# -----------------------------------------------------------------------------
# optional collector credentials
# -----------------------------------------------------------------------------
CGV_ID=your-cgv-id
CGV_PASSWORD=your-cgv-password
CGV_API_SECRET=your-cgv-api-secret

LOTTE_ID=your-lotte-id
LOTTE_PASSWORD=your-lotte-password

MEGABOX_ID=your-megabox-id
MEGABOX_PASSWORD=your-megabox-password

# -----------------------------------------------------------------------------
# optional collector database and storage
# -----------------------------------------------------------------------------
# Use this block only when you want collector-specific DB settings that differ
# from the backend `DABOYEO_DB_*` values above.
TIDB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-prefix.root
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=daboyeo_dev
TIDB_SSL=true
# `DATABASE_URL` is also supported for collector scripts when `TIDB_*` is unset.
DATABASE_URL=mysql://your-prefix.root:your-tidb-password@gateway01.ap-northeast-1.prod.aws.tidbcloud.com:4000/daboyeo_dev

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=daboyeo-raw
R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=
